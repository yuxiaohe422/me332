<?xml version="1.0"?>
<robot name="arm_wheel" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="pi" value="3.14159265359"/>

  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width" value="0.06"/>
  <xacro:property name="base_radius" value="0.18"/>
  <xacro:property name="base_height" value="0.08"/>

  <xacro:property name="cone_radius" value="0.08"/>
  <xacro:property name="cone_height" value="0.08"/>

  <xacro:property name="arm_radius" value="0.03"/>
  <xacro:property name="arm_length" value="0.20"/>
  <xacro:property name="arm_lenght_upper" value="0.16"/>

  <xacro:property name="gripper_base_length" value="0.08"/>
  <xacro:property name="gripper_base_width" value="0.15"/>
  <xacro:property name="gripper_base_height" value="0.05"/>
  <xacro:property name="gripper_finger_height" value="0.01"/>
  <xacro:property name="finger_mass" value="0.05"/>

  <!-- 雷达参数 -->
  <xacro:property name="lidar_radius" value="0.01"/>
  <xacro:property name="lidar_height" value="0.02"/>
  <xacro:property name="lidar_mass" value="0.01"/>

  <!-- 定义夹爪手指尺寸的各个分量 -->
  <xacro:property name="finger_lx" value="0.01"/>
  <xacro:property name="finger_ly" value="0.02"/>
  <xacro:property name="finger_lz" value="0.08"/>

  <material name="blue"><color rgba="0 0 0.8 0.8"/></material>
  <material name="black"><color rgba="0 0 0 0.5"/></material>
  <material name="white"><color rgba="1 1 1 0.8"/></material>
  <material name="red"><color rgba="1 0 0 0.8"/></material>

  <!-- inertia -->

  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass * (3*radius*radius + length*length)/12}" ixy="0" ixz="0"
               iyy="${mass * (3*radius*radius + length*length)/12}" iyz="0"
               izz="${mass * radius*radius / 2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_inertia" params="mass lx ly lz">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(ly*ly + lz*lz)/12}" ixy="0" ixz="0"
               iyy="${mass*(lx*lx + lz*lz)/12}" iyz="0"
               izz="${mass*(lx*lx + ly*ly)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- 雷达宏定义 -->
  <xacro:macro name="lidar" params="prefix">
    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia mass="${lidar_mass}" radius="${lidar_radius}" length="${lidar_height}"/>
    </link>

    <joint name="${prefix}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="${cone_radius-lidar_radius} 0 ${base_height/2+cone_height}" rpy="0 0 0"/>
    </joint>

    <!-- Gazebo雷达插件 -->
    <gazebo reference="${prefix}_link">
      <sensor type="ray" name="${prefix}">
        <pose>0 0 0 0 0 0</pose>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>30.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="gazebo_ros_${prefix}_controller" filename="libgazebo_ros_laser.so">
          <ros>
            <namespace>/</namespace>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>${prefix}_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <!-- wheels macro -->
  <xacro:macro name="wheel" params="prefix suffix reflect">
    <link name="${prefix}_${suffix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia mass="0.5" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="${prefix}_${suffix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_${suffix}_wheel"/>
      <origin xyz="0 ${reflect * base_radius} -${wheel_radius*0.3}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- main urdf -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="5.0" radius="${base_radius}" length="${base_height}"/>
  </link>

  <xacro:wheel prefix="base" suffix="left" reflect="1"/>
  <xacro:wheel prefix="base" suffix="right" reflect="-1"/>

  <!-- 添加雷达传感器，放在轮子前面 -->
  <xacro:lidar prefix="laser"/>

  <link name="cone_link">
    <visual>
      <origin xyz="0 0 ${cone_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cone_radius}" length="${cone_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${cone_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cone_radius}" length="${cone_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.0" radius="${cone_radius}" length="${cone_height}"/>
  </link>

  <joint name="base_to_cone" type="continuous">
    <parent link="base_link"/>
    <child link="cone_link"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!--  -->

  <link name="sphere_1">
    <visual>
      <origin xyz="0 0 ${base_height/2+cone_height}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${arm_radius}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2+cone_height}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${cone_radius}"/>
      </geometry>
    </collision>
  </link>

  <!--  -->

  <link name="arm_lower">
    <visual>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.4" radius="${arm_radius}" length="${arm_length}"/>
  </link>

  <joint name="cone_to_lower" type="revolute">
    <parent link="cone_link"/>
    <child link="arm_lower"/>
    <origin xyz="0 0 ${cone_height}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="1.0"/>
  </joint>

  <link name="arm_middle">
    <visual>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.4" radius="${arm_radius}" length="${arm_length}"/>
  </link>

  <joint name="lower_to_middle" type="revolute">
    <parent link="arm_lower"/>
    <child link="arm_middle"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="1.0"/>
  </joint>

  <link name="arm_upper">
    <visual>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.4" radius="${arm_radius}" length="${arm_length}"/>
  </link>

  <joint name="middle_to_upper" type="revolute">
    <parent link="arm_middle"/>
    <child link="arm_upper"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="1.0"/>
  </joint>

  <!-- gripper -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 ${gripper_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${gripper_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="0.3" lx="${gripper_base_length}" ly="${gripper_base_width}" lz="${gripper_base_height}"/>
  </link>

  <joint name="arm_upper_to_gripper" type="continuous">
    <parent link="arm_upper"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <xacro:macro name="gripper_finger" params="suffix reflect">
    <link name="finger_${suffix}">
      <visual>
        <origin xyz="0 ${reflect*finger_ly/2} ${gripper_base_height/2 + finger_lz/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_lx} ${finger_ly} ${finger_lz}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 ${reflect*finger_ly/2} ${gripper_base_height/2 + finger_lz/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_lx} ${finger_ly} ${finger_lz}"/>
        </geometry>
      </collision>
      <xacro:box_inertia mass="${finger_mass}" 
                         lx="${finger_lx}" 
                         ly="${finger_ly}" 
                         lz="${finger_lz}"/>
    </link>

    <joint name="gripper_to_finger_${suffix}" type="prismatic">
      <parent link="gripper_base"/>
      <child link="finger_${suffix}"/>
      <origin xyz="0 0 ${0.8*gripper_base_height/2}" rpy="0 0 0"/>
      <axis xyz="0 ${reflect} 0"/> <!-- 根据reflect调整轴方向 -->
      <limit lower="0" upper="0.04" effort="10" velocity="0.5"/>
    </joint>
  </xacro:macro>

  <!-- 使用正负reflect值控制两个手指的同步运动(但在控制面板上表现为分别拉动进度条控制两根finger) -->
  <xacro:gripper_finger suffix="left" reflect="1"/>
  <xacro:gripper_finger suffix="right" reflect="-1"/>

</robot>