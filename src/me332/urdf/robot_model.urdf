<?xml version="1.0"?>
<robot name="me332_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.06"/>
  <xacro:property name="base_radius" value="0.15"/>
  <xacro:property name="base_height" value="0.07"/>

  <xacro:property name="cone_radius" value="0.06"/>
  <xacro:property name="cone_height" value="0.06"/>

  <xacro:property name="arm_radius" value="0.02"/>
  <xacro:property name="arm_length" value="0.18"/>

  <xacro:property name="gripper_base_length" value="0.06"/>
  <xacro:property name="gripper_base_width" value="0.12"/>
  <xacro:property name="gripper_base_height" value="0.04"/>
  <xacro:property name="gripper_finger_height" value="0.01"/>
  <xacro:property name="finger_mass" value="0.05"/>

  <xacro:property name="lidar_radius" value="0.01"/>
  <xacro:property name="lidar_height" value="0.02"/>
  <xacro:property name="lidar_mass" value="0.01"/>

  <xacro:property name="finger_lx" value="0.01"/>
  <xacro:property name="finger_ly" value="0.02"/>
  <xacro:property name="finger_lz" value="0.08"/>

  <xacro:property name="omni_radius" value="${1.3*wheel_radius-0.5*base_height}"/>

  <material name="blue"><color rgba="0 0 0.8 0.8"/></material>
  <material name="black"><color rgba="0 0 0 0.5"/></material>
  <material name="white"><color rgba="1 1 1 0.8"/></material>
  <material name="red"><color rgba="1 0 0 0.8"/></material>

  <!-- inertia -->
  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass * (3*radius*radius + length*length)/12}" ixy="0" ixz="0"
               iyy="${mass * (3*radius*radius + length*length)/12}" iyz="0"
               izz="${mass * radius*radius / 2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_inertia" params="mass lx ly lz">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(ly*ly + lz*lz)/12}" ixy="0" ixz="0"
               iyy="${mass*(lx*lx + lz*lz)/12}" iyz="0"
               izz="${mass*(lx*lx + ly*ly)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(2/5) * mass * (radius*radius)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * mass * (radius*radius)}" iyz="0.0" izz="${(2/5) * mass * (radius*radius)}"/>
    </inertial>
  </xacro:macro>
  <!--  -->

  <xacro:macro name="wheel" params="prefix suffix reflect">
    <link name="${prefix}_${suffix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <xacro:cylinder_inertia mass="0.5" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="${prefix}_${suffix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_${suffix}_wheel"/>
      <origin xyz="0 ${reflect * base_radius} -${wheel_radius*0.3}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <link name="base_footprint">
    <xacro:box_inertia mass="0.0" lx="0.0" ly="0.0" lz="0.0"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${base_radius}" length="${base_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2" radius="${base_radius}" length="${base_height}"/>
  </link>

  <xacro:wheel prefix="base" suffix="left" reflect="1"/>
  <xacro:wheel prefix="base" suffix="right" reflect="-1"/>


  <link name="odom">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia mass="0.1" radius="0.03"/>
  </link>
  <!-- Make odom the parent of the base_footprint so TF tree becomes:
       odom -> base_footprint -> base_link -->
  <joint name="odom_to_base_footprint" type="fixed">
    <parent link="odom"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="omni_wheel_front">
    <visual>
      <origin xyz="${base_radius-0.03} 0 -${base_height/2-0.03}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="${base_radius-0.03} 0 -${base_height/2-0.03}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="white"/>
    </collision>
    <xacro:sphere_inertia mass="0.1" radius="0.03"/>
  </link>
  <!-- try "omni_radius" to replace 0.03 if have to change total size. -->
  <!-- Make balancing ball low-friction so it doesn't lock the chassis -->
  <gazebo reference="omni_wheel_front">
    <surface>
      <friction>
        <ode>
          <mu>0.0</mu>
          <mu2>0.0</mu2>
        </ode>
      </friction>
    </surface>
  </gazebo>

  <joint name="base_to_omni_front" type="fixed">
    <parent link="base_link"/>
    <child link="omni_wheel_front"/>
    <!-- Lift slightly so drive wheels carry the weight -->
    <origin xyz="0 0 -${base_height/2 - 0.01}" rpy="0 0 0"/>
    <!-- <axis xyz="0 0 1"/> -->
  </joint>

  <link name="omni_wheel_back">
    <visual>
      <origin xyz="-${base_radius-0.03} 0 -${base_height/2-0.03}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-${base_radius-0.03} 0 -${base_height/2-0.03}" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="white"/>
    </collision>
    <xacro:sphere_inertia mass="0.1" radius="0.03"/>
  </link>
  <!-- try "omni_radius" to replace 0.03 if have to change total size. -->
  <!-- Make balancing ball low-friction so it doesn't lock the chassis -->
  <gazebo reference="omni_wheel_back">
    <surface>
      <friction>
        <ode>
          <mu>0.0</mu>
          <mu2>0.0</mu2>
        </ode>
      </friction>
    </surface>
  </gazebo>

  <joint name="base_to_omni_back" type="fixed">
    <parent link="base_link"/>
    <child link="omni_wheel_back"/>
    <!-- Lift slightly so drive wheels carry the weight -->
    <origin xyz="0 0 -${base_height/2 - 0.01}" rpy="0 0 0"/>
    <!-- <axis xyz="0 0 1"/> -->
  </joint>

  <link name="cone_link">
    <visual>
      <origin xyz="0 0 ${cone_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cone_radius}" length="${cone_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${cone_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${cone_radius}" length="${cone_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="2.0" radius="${cone_radius}" length="${cone_height}"/>
  </link>

  <joint name="base_to_cone" type="continuous">
    <parent link="base_link"/>
    <child link="cone_link"/>
    <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <!-- lidar -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="${cone_radius} 0 ${base_height/2 + cone_height}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="${lidar_mass}" radius="${lidar_radius}" length="${lidar_height}"/>
  </link>

  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="${cone_radius} 0 ${base_height/2 + cone_height}" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo GPU lidar publishing /scan (align with robot_model.xacro) -->
  <gazebo reference="laser_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <topic>/scan</topic>
      <gz_frame_id>laser_link</gz_frame_id>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>6.28319</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>5.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
    </sensor>
  </gazebo>

  <!-- Use Gazebo (Ignition) native systems for sensors and diff drive, keep omni wheel geometry unchanged -->
  <gazebo>
    <plugin filename="libgz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="libgz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic> 
    </plugin>
    <plugin filename="libgz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>base_left_wheel_joint</left_joint>
      <right_joint>base_right_wheel_joint</right_joint>
      <wheel_separation>${base_radius*2}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame>odom</frame>
      <publish_odom>false</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <ros2_control name="ArmSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="base_to_cone">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="cone_to_lower">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lower_to_middle">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="middle_to_upper">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper_to_finger_left">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper_to_finger_right">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
      <parameters>$(find me332)/config/ros2_controller.yaml</parameters>
    </plugin>
  </gazebo>

  <link name="arm_lower">
    <visual>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.4" radius="${arm_radius}" length="${arm_length}"/>
  </link>

  <joint name="cone_to_lower" type="revolute">
    <parent link="cone_link"/>
    <child link="arm_lower"/>
    <origin xyz="0 0 ${cone_height}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="1.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <link name="arm_middle">
    <visual>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.4" radius="${arm_radius}" length="${arm_length}"/>
  </link>

  <joint name="lower_to_middle" type="revolute">
    <parent link="arm_lower"/>
    <child link="arm_middle"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="1.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <link name="arm_upper">
    <visual>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.4" radius="${arm_radius}" length="${arm_length}"/>
  </link>

  <joint name="middle_to_upper" type="revolute">
    <parent link="arm_middle"/>
    <child link="arm_upper"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi/2}" upper="${pi/2}" effort="10" velocity="1.0"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <!-- gripper -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 ${gripper_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${gripper_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${gripper_base_length} ${gripper_base_width} ${gripper_base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="0.3" lx="${gripper_base_length}" ly="${gripper_base_width}" lz="${gripper_base_height}"/>
  </link>

  <joint name="arm_upper_to_gripper" type="fixed">
    <parent link="arm_upper"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="gripper_finger" params="suffix reflect">
    <link name="finger_${suffix}">
      <visual>
        <origin xyz="0 ${reflect*finger_ly/2} ${gripper_base_height/2 + finger_lz/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_lx} ${finger_ly} ${finger_lz}"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 ${reflect*finger_ly/2} ${gripper_base_height/2 + finger_lz/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_lx} ${finger_ly} ${finger_lz}"/>
        </geometry>
      </collision>
      <xacro:box_inertia mass="${finger_mass}" 
                         lx="${finger_lx}" 
                         ly="${finger_ly}" 
                         lz="${finger_lz}"/>
    </link>

    <joint name="gripper_to_finger_${suffix}" type="prismatic">
      <parent link="gripper_base"/>
      <child link="finger_${suffix}"/>
      <origin xyz="0 0 ${0.8*gripper_base_height/2}" rpy="0 0 0"/>
      <axis xyz="0 ${reflect} 0"/> <!-- 根据reflect调整轴方向 -->
      <limit lower="0" upper="0.04" effort="10" velocity="0.5"/>
      <dynamics damping="1.0" friction="0.5"/>
    </joint>
  </xacro:macro>

  <xacro:gripper_finger suffix="left" reflect="1"/>
  <xacro:gripper_finger suffix="right" reflect="-1"/>

</robot>
